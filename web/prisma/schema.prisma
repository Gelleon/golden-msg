generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                          String               @id @default(uuid())
  email                       String               @unique
  full_name                   String?
  avatar_url                  String?
  role                        String               @default("client")
  preferred_language          String               @default("ru")
  password_hash               String               @default("")
  created_at                  DateTime             @default(now())
  last_active_at              DateTime             @default(now())
  email_notifications_enabled Boolean              @default(true)
  push_notifications_enabled  Boolean              @default(true)
  last_email_notification_at  DateTime?
  last_push_notification_at   DateTime?
  last_password_reset_at      DateTime?
  audit_logs                  AuditLog[]
  messages_sent               Message[]
  sent_notifications          NotificationLog[]
  reset_tokens                PasswordResetToken[]
  push_subscriptions          PushSubscription[]
  owned_rooms                 Room[]
  created_invites             RoomInvite[]         @relation("CreatedInvites")
  room_participations         RoomParticipant[]
}

model PushSubscription {
  id         String   @id @default(uuid())
  user_id    String
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  ip_address String?
  action     String
  details    String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])
}

model Room {
  id           String            @id @default(uuid())
  name         String?
  description  String?
  capacity     Int?              @default(0)
  equipment    String?
  type         String            @default("private")
  created_by   String?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @default(now()) @updatedAt
  room_id      String?
  messages     Message[]
  owner        User?             @relation(fields: [created_by], references: [id])
  invites      RoomInvite[]
  participants RoomParticipant[]
}

model RoomParticipant {
  id             String    @id @default(uuid())
  room_id        String
  user_id        String
  role           String    @default("member")
  joined_at      DateTime  @default(now())
  last_read_at   DateTime  @default(now())
  last_active_at DateTime  @default(now())
  typing_at      DateTime?
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  room           Room      @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([room_id, user_id])
}

model Message {
  id                  String    @id @default(uuid())
  room_id             String
  sender_id           String
  content             String?
  content_translated  String?
  language_original   String?   @default("ru")
  message_type        String    @default("text")
  file_url            String?
  voice_transcription String?
  created_at          DateTime  @default(now())
  is_edited           Boolean   @default(false)
  reply_to_id         String?
  translation_status  String    @default("completed")
  translation_error   String?
  is_pinned           Boolean?  @default(false)
  is_important        Boolean?  @default(false)
  reply_to            Message?  @relation("MessageReplies", fields: [reply_to_id], references: [id])
  replies             Message[] @relation("MessageReplies")
  sender              User      @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  room                Room      @relation(fields: [room_id], references: [id], onDelete: Cascade)
}

model RoomInvite {
  id         String   @id @default(uuid())
  token      String   @unique
  room_id    String
  created_by String
  role       String   @default("client")
  expires_at DateTime
  max_uses   Int      @default(1)
  uses       Int      @default(0)
  created_at DateTime @default(now())
  creator    User     @relation("CreatedInvites", fields: [created_by], references: [id], onDelete: Cascade)
  room       Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id       String   @id @default(uuid())
  user_id  String
  email    String
  type     String   @default("unread_messages")
  status   String
  error    String?
  sent_at  DateTime @default(now())
  metadata String?
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
