// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  full_name          String?
  avatar_url         String?
  role               String   @default("client") // admin, manager, partner, client
  preferred_language String   @default("ru") // ru, cn
  password_hash      String   @default("") // temporary default for migration
  created_at         DateTime @default(now())

  // Notification Settings
  email_notifications_enabled Boolean @default(true)
  push_notifications_enabled  Boolean @default(true)
  last_email_notification_at DateTime?
  last_push_notification_at  DateTime?
  last_password_reset_at    DateTime?

  // Relations
  messages_sent      Message[]
  room_participations RoomParticipant[]
  owned_rooms        Room[]
  created_invites    RoomInvite[] @relation("CreatedInvites")
  sent_notifications NotificationLog[]
  reset_tokens       PasswordResetToken[]
  audit_logs         AuditLog[]
  push_subscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  user_id   String
  endpoint  String   @unique
  p256dh    String
  auth      String
  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  ip_address String?
  action     String   // e.g., "PASSWORD_RESET_REQUESTED", "PASSWORD_RESET_SUCCESSFUL", "LOGIN_FAILED"
  details    String?  // JSON or string
  created_at DateTime @default(now())

  // Relations
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

model Room {
  id          String   @id @default(uuid())
  name        String?
  description String?
  capacity    Int?     @default(0)
  equipment   String?  // JSON string or comma-separated list
  type        String   @default("private") // private, group
  created_by  String?
  room_id     String?  // Associated room for DMs
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  // Relations
  owner        User?    @relation(fields: [created_by], references: [id])
  participants RoomParticipant[]
  messages     Message[]
  invites      RoomInvite[]
}

model RoomParticipant {
  id        String   @id @default(uuid())
  room_id   String
  user_id   String
  role      String   @default("member") // owner, admin, member
  joined_at DateTime @default(now())
  last_read_at DateTime @default(now())
  last_active_at DateTime @default(now()) // Track last activity specifically
  typing_at DateTime?

  // Relations
  room Room @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([room_id, user_id])
}

model Message {
  id                 String   @id @default(uuid())
  room_id            String
  sender_id          String
  content            String?
  content_translated String?
  language_original  String?  @default("ru") // ru, cn
  message_type       String   @default("text") // text, voice, file
  file_url           String?
  voice_transcription String?
  created_at         DateTime @default(now())
  is_edited          Boolean  @default(false)
  reply_to_id        String?
  translation_status String   @default("completed") // pending, completed, failed, cancelled
  translation_error  String?
  is_pinned          Boolean  @default(false)
  is_important       Boolean  @default(false)

  // Relations
  room   Room @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender User @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  reply_to Message? @relation("MessageReplies", fields: [reply_to_id], references: [id], onDelete: SetNull)
  replies  Message[] @relation("MessageReplies")
  deletion_logs FileDeletionLog[]
}

model FileDeletionLog {
  id          String   @id @default(uuid())
  message_id  String
  room_id     String
  file_url    String
  backup_path String
  deleted_at  DateTime @default(now())
  expires_at  DateTime

  // Relations
  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
}

model RoomInvite {
  id          String   @id @default(uuid())
  token       String   @unique
  room_id     String
  created_by  String
  role        String   @default("client") // partner, client
  expires_at  DateTime
  max_uses    Int      @default(1)
  uses        Int      @default(0)
  created_at  DateTime @default(now())

  // Relations
  room       Room @relation(fields: [room_id], references: [id], onDelete: Cascade)
  creator    User @relation("CreatedInvites", fields: [created_by], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id          String   @id @default(uuid())
  user_id     String
  email       String
  type        String   @default("unread_messages")
  status      String   // sent, failed
  error       String?
  sent_at     DateTime @default(now())
  metadata    String?  // JSON with room names and counts

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
